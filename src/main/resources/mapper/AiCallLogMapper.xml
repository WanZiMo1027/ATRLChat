<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yuntian.chat_app.mapper.userMapper.AiCallLogMapper">

    <resultMap id="BaseResultMap" type="com.yuntian.chat_app.entity.AiCallLogDO">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="characterId" column="character_id"/>
        <result property="modelName" column="model_name"/>
        <result property="memoryId" column="memory_id"/>
        <result property="status" column="status"/>
        <result property="inputTokens" column="input_tokens"/>
        <result property="outputTokens" column="output_tokens"/>
        <result property="totalTokens" column="total_tokens"/>
        <result property="durationMs" column="duration_ms"/>
        <result property="requestTs" column="request_ts"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 插入记录 -->
    <insert id="insert" parameterType="com.yuntian.chat_app.entity.AiCallLogDO"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_call_log
        (user_id, character_id, model_name, memory_id, status,
         input_tokens, output_tokens, total_tokens, duration_ms, request_ts)
        VALUES
            (#{userId}, #{characterId}, #{modelName}, #{memoryId}, #{status},
             #{inputTokens}, #{outputTokens}, #{totalTokens}, #{durationMs}, #{requestTs})
    </insert>

    <!-- 查询最后一条记录 -->
    <select id="findLatestByMemoryId" resultMap="BaseResultMap">
        SELECT *
        FROM ai_call_log
        WHERE memory_id = #{memoryId}
          AND status = 'success'
        ORDER BY request_ts DESC
        LIMIT 1
    </select>

    <!-- 查询所有记录（按时间倒序） -->
    <select id="findAllByMemoryId" resultMap="BaseResultMap">
        SELECT *
        FROM ai_call_log
        WHERE memory_id = #{memoryId}
          AND status = 'success'
          AND request_ts >= DATE_SUB(NOW(), INTERVAL 30 DAY)
        ORDER BY request_ts DESC
        LIMIT 1000
    </select>

</mapper>