<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yuntian.chat_app.mapper.userMapper.ChatGroupMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.yuntian.chat_app.entity.ChatGroup">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="avatar_url" property="avatarUrl"/>
        <result column="creator_id" property="creatorId"/>
        <result column="character_id" property="characterId"/>
        <result column="description" property="description"/>
        <result column="max_members" property="maxMembers"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.yuntian.chat_app.entity.ChatGroup"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_group (
            id, name, avatar_url, creator_id, character_id,
            description, max_members, create_time, update_time
        ) VALUES (
                     #{id}, #{name}, #{avatarUrl}, #{creatorId}, #{characterId},
                     #{description}, #{maxMembers}, NOW(), NOW()
                 )
    </insert>

    <!-- 根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM chat_group
        WHERE id = #{id} AND is_deleted = 0
    </select>

    <!-- 根据创建者查询 -->
    <select id="selectByCreatorId" resultMap="BaseResultMap">
        SELECT * FROM chat_group
        WHERE creator_id = #{creatorId} AND is_deleted = 0
        ORDER BY create_time DESC
    </select>

    <!-- 更新 -->
    <update id="updateById">
        UPDATE chat_group
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="avatarUrl != null">avatar_url = #{avatarUrl},</if>
            <if test="description != null">description = #{description},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 逻辑删除 -->
    <update id="deleteById">
        UPDATE chat_group
        SET is_deleted = 1, update_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>
